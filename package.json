{
  "name": "adminjs-ecommerce-backend",
  "version": "1.0.0",
  "description": "A secure Role-Based eCommerce Admin Dashboard built with AdminJS, Sequelize, and PostgreSQL. Features JWT authentication, custom dashboards, and managed access control for Admins and Regular Users.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "ts-node": {
    "esm": true,
    "experimentalResolver": true,
    "experimentalSpecifierResolution": "node"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gihanmadhusankha/adminjs-ecommerce-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Gihanmadhusankha/adminjs-ecommerce-backend/issues"
  },
  "homepage": "https://github.com/Gihanmadhusankha/adminjs-ecommerce-backend#readme",
  "dependencies": {
    "@adminjs/express": "^6.1.1",
    "@adminjs/sequelize": "^4.1.1",
    "adminjs": "^7.8.17",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
